# =============================================================================
# VayuGuard - .gitignore
# =============================================================================
# Comprehensive gitignore for Node.js, Python, Docker, and infrastructure
# =============================================================================

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
*/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
dist/
build/
.next/
out/
.turbo/

# Frontend
frontend/.next/
frontend/out/
frontend/dist/

# Backend
backend/dist/
backend/build/

# ML Service
ml-service/__pycache__/
ml-service/**/__pycache__/
ml-service/dist/
ml-service/*.egg-info/

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging
!.env.dev
!.env.example

# ---------------------------------------------------------------------------
# IDE & Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
.Python
venv/
env/
.venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ML artifacts
ml-service/models/*.pkl
ml-service/models/*.joblib
ml-service/models/*.h5
ml-service/models/*.pt
ml-service/models/*.onnx
ml-service/models/*.bin
!ml-service/models/.gitkeep
ml-service/data/raw/
ml-service/data/processed/
ml-service/artifacts/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
db/*.db
db/*.sqlite
*.sqlite3
mongodata/
pgdata/
redisdata/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/
htmlcov/
.pytest_cache/
.coverage
.coverage.*

# ---------------------------------------------------------------------------
# Terraform
# ---------------------------------------------------------------------------
infrastructure/terraform/.terraform/
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.*
infrastructure/terraform/.terraform.lock.hcl
infrastructure/terraform/*.tfplan
infrastructure/terraform/*.tfplan.*

# ---------------------------------------------------------------------------
# Kubernetes
# ---------------------------------------------------------------------------
kubeconfig

# ---------------------------------------------------------------------------
# Backups
# ---------------------------------------------------------------------------
backups/
*.dump
*.sql.gz
*.tar.gz
!infrastructure/monitoring/grafana-dashboards/*.json

# ---------------------------------------------------------------------------
# Uploads
# ---------------------------------------------------------------------------
uploads/

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.cache/
.parcel-cache/
