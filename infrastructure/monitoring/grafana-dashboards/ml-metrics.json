{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "VayuGuard ML Model Performance Dashboard - Tracks prediction accuracy, latency, and model drift",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "ML Model Performance Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Mean Absolute Error (MAE)",
      "description": "Average absolute difference between predicted and actual AQI values",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "prediction_mae",
          "legendFormat": "MAE",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "Root Mean Square Error (RMSE)",
      "description": "Root mean square error of predictions - penalizes larger errors more heavily",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "prediction_rmse",
          "legendFormat": "RMSE",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 40 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "R² Score",
      "description": "Coefficient of determination - proportion of variance explained by the model",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "prediction_r2_score",
          "legendFormat": "R²",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "Prediction Throughput",
      "description": "Number of predictions per second",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "rate(prediction_requests_total[5m])",
          "legendFormat": "req/s",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Prediction Latency (p50, p95, p99)",
      "description": "Latency distribution for ML prediction requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "title": "MAE Over Time",
      "description": "Trend of Mean Absolute Error to detect model drift",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "expr": "prediction_mae",
          "legendFormat": "MAE",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "thresholdsStyle": { "mode": "line" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 25 }
              ]
            }
          }
        }
      }
    },
    {
      "title": "RMSE Over Time",
      "description": "Trend of RMSE showing model accuracy over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [
        {
          "expr": "prediction_rmse",
          "legendFormat": "RMSE",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "title": "Prediction Errors by Type",
      "description": "Breakdown of prediction errors by category",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [
        {
          "expr": "rate(prediction_errors_total[5m])",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "errors/s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "stacking": { "mode": "normal" }
          }
        }
      }
    },
    {
      "title": "Model Drift Detection",
      "description": "Feature distribution shift indicators over time",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 21 },
      "targets": [
        {
          "expr": "model_drift_score",
          "legendFormat": "Drift Score",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "orange", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "title": "Feature Importance",
      "description": "Top contributing features to model predictions",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 21 },
      "targets": [
        {
          "expr": "feature_importance_score",
          "legendFormat": "{{feature_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["vayuguard", "ml", "model-performance"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(prediction_mae, model_version)",
        "hide": 0,
        "includeAll": true,
        "label": "Model Version",
        "multi": true,
        "name": "model_version",
        "options": [],
        "query": "label_values(prediction_mae, model_version)",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "VayuGuard - ML Model Performance",
  "uid": "vayuguard-ml-metrics",
  "version": 1
}
