# VayuGuard Backend Environment Variables
# Copy this to .env for local development

# Server
NODE_ENV=development
PORT=5000

# MongoDB (required for full mode; if not available, runs in standalone mode)
MONGODB_URI=mongodb://localhost:27017/vayuguard

# Redis (optional; in-memory fallback used if not available)
REDIS_URL=redis://localhost:6379

# ML Service (optional; forecast endpoints return demo data if not available)
ML_SERVICE_URL=http://localhost:8000

# Authentication
JWT_SECRET=dev-jwt-secret-change-in-production-abc123
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
