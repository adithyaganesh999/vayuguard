# =============================================================================
# VayuGuard - Development Environment Variables
# =============================================================================
# Copy this file to .env for local development
# =============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
NODE_ENV=development
TZ=UTC

# ---------------------------------------------------------------------------
# Backend (Express.js)
# ---------------------------------------------------------------------------
PORT=5000
MONGODB_URI=mongodb://vayuguard:vayuguard123@localhost:27017/vayuguard?authSource=admin
POSTGRES_URI=postgresql://vayuguard:vayuguard123@localhost:5432/vayuguard
REDIS_URL=redis://:vayuguard123@localhost:6379
ML_SERVICE_URL=http://localhost:8000

# Authentication
JWT_SECRET=dev-jwt-secret-change-in-production-abc123
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Frontend (Next.js)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_ML_API_URL=http://localhost:8000/api/ml
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_WS_URL=ws://localhost:5000/ws

# ---------------------------------------------------------------------------
# ML Service (FastAPI)
# ---------------------------------------------------------------------------
ML_PORT=8000
ML_WORKERS=2
ML_LOG_LEVEL=DEBUG
MODEL_PATH=./models/
REDIS_URL_ML=redis://:vayuguard123@localhost:6379

# ---------------------------------------------------------------------------
# Data Pipeline
# ---------------------------------------------------------------------------
PIPELINE_SCHEDULE_CRON=*/15 * * * *
CPCB_API_KEY=your-cpcb-api-key-here
OPENAQ_API_KEY=your-openaq-api-key-here
WAQI_API_KEY=your-waqi-api-key-here

# ---------------------------------------------------------------------------
# Email (optional, for alert notifications)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@vayuguard.app

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=vayuguard-admin

# ---------------------------------------------------------------------------
# Docker Compose
# ---------------------------------------------------------------------------
DOCKER_REGISTRY=vayuguard
COMPOSE_PROJECT_NAME=vayuguard
